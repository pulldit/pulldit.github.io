{
  "manifest_version": 3,
  "name": "Pulldit Bridge",
  "version": "1.0.0",
  "description": "Lets pulldit.github.io download Reddit media and build ZIPs from YOUR own IP — no proxy, no CORS limits. Locked to Reddit/imgur hosts.",
  "homepage_url": "https://github.com/pulldit/pulldit.github.io/tree/main/extension",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Pulldit Bridge — open pulldit.github.io to use it",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://pulldit.github.io/*",
        "http://localhost:8080/*",
        "http://127.0.0.1:8080/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "host_permissions": [
    "https://www.reddit.com/*",
    "https://old.reddit.com/*",
    "https://i.redd.it/*",
    "https://v.redd.it/*",
    "https://preview.redd.it/*",
    "https://external-preview.redd.it/*",
    "https://*.redditmedia.com/*",
    "https://i.imgur.com/*",
    "https://imgur.com/*"
  ]
}
